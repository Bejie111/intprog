@model BreadBee.Models.User
@{
    var role = Context.Session.GetString("Role");
}

<link rel="stylesheet" href="~/css/profile.css" />

<div class="profile-wrapper">

    <!-- HEADER -->
    <div class="profile-header">
        <div>
            <div class="profile-title">👤 Profile Settings</div>
            <div class="profile-subtitle">Manage your account information</div>
        </div>
        <div class="profile-role-badge @(role == "Admin" ? "admin-badge" : "customer-badge")">
            @if (role == "Admin")
            {
                <i class="bi bi-shield-fill"></i>
            }
            else
            {
                <i class="bi bi-person-fill"></i>
            }
            @role
        </div>
    </div>

    <!-- FORM CARD -->
    <div class="profile-card">

        <!-- AVATAR SECTION -->
        <div class="avatar-section">
            <div class="avatar-circle">
                @(Model.FullName?[0].ToString().ToUpper() ?? "U")
            </div>
            <div class="avatar-info">
                <div class="avatar-name">@Model.FullName</div>
                <div class="avatar-email">@Model.Email</div>
            </div>
        </div>

        <div class="card-divider"></div>

        <!-- FORM -->
        <form asp-action="UpdateProfile" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-person-fill"></i> Full Name
                </label>
                <input asp-for="FullName" class="form-input" placeholder="Enter your full name" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-envelope-fill"></i> Email Address
                </label>
                <input asp-for="Email" class="form-input" placeholder="Enter your email" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-telephone-fill"></i> Phone Number
                </label>
                <input asp-for="PhoneNumber" class="form-input" placeholder="Enter your phone number" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-shield-fill"></i> Role
                </label>
                <input asp-for="Role" class="form-input form-input-readonly" readonly />
                <small class="form-hint">Role cannot be changed here.</small>
            </div>

            <div class="card-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
                @if (role == "Admin")
                {
                    <a asp-controller="Admin"
                       asp-action="Dashboard"
                       class="btn-cancel">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                }
                else
                {
                    <a asp-controller="Product"
                       asp-action="Products"
                       class="btn-cancel">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                }
            </div>

        </form>
    </div>
</div>