@model IEnumerable<dynamic>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<!-- TOP HEADER -->
<div class="dash-header">
    <div>
        <div class="dash-title">Overview Dashboard</div>
        <div class="dash-subtitle">Welcome back, Admin 👋 Here's what's happening today.</div>
    </div>
    <div class="live-badge">
        <i class="bi bi-circle-fill"></i> Live Updates
    </div>
</div>

<!-- STAT CARDS -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-icon orders-icon">
            <i class="bi bi-bag-check-fill"></i>
        </div>
        <div class="stat-info">
            <div class="stat-label">Total Orders</div>
            <div class="stat-value">@ViewBag.TotalOrders</div>
        </div>
        <div class="stat-sparkle">📦</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon sales-icon">
            <i class="bi bi-currency-exchange"></i>
        </div>
        <div class="stat-info">
            <div class="stat-label">Total Sales</div>
            <div class="stat-value sales-value">₱@ViewBag.TotalSales</div>
        </div>
        <div class="stat-sparkle">💰</div>
    </div>
</div>

<!-- ORDERS TABLE -->
<div class="orders-card">
    <div class="orders-card-header">
        <div>
            <div class="orders-title">
                <i class="bi bi-receipt-cutoff"></i> Recent Invoices & Orders
            </div>
            <div class="orders-subtitle">All customer orders and transactions</div>
        </div>
        <div class="orders-hint">
            <i class="bi bi-arrow-down-up"></i> Scroll to view more
        </div>
    </div>

    <div class="table-wrap">
        <table class="orders-table">
            <thead>
                <tr>
                    <th class="ps-col">Customer</th>
                    <th>Order Date</th>
                    <th>Subtotal</th>
                    <th class="col-discount">Discount</th>
                    <th class="col-final">Final Amount</th>
                    <th class="text-center">Breakdown</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    int index = 0;
                    foreach (var order in Model)
                    {
                        index++;
                        string collapseId = $"itemsCollapse_{index}";
                        string initial = string.IsNullOrEmpty((string)order.CustomerName)
                        ? "U"
                        : ((string)order.CustomerName).Substring(0, 1).ToUpper();

                        <tr class="order-row">
                            <td class="ps-col">
                                <div class="customer-cell">
                                    <div class="customer-avatar">@initial</div>
                                    <span class="customer-name">@order.CustomerName</span>
                                </div>
                            </td>
                            <td class="date-cell">@order.OrderDate</td>
                            <td class="amount-cell">₱@order.TotalAmount</td>
                            <td class="discount-cell">−₱@order.Discount</td>
                            <td class="final-cell">₱@order.FinalAmount</td>
                            <td class="text-center">
                                <button class="view-btn"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="false">
                                    <i class="bi bi-eye-fill"></i> View Items
                                </button>
                            </td>
                        </tr>

                        <tr class="collapse" id="@collapseId">
                            <td colspan="6" class="collapse-cell">
                                <div class="items-log">
                                    <div class="items-log-title">
                                        <i class="bi bi-cart3"></i> Purchased Items — @order.CustomerName
                                    </div>
                                    <div class="items-grid">
                                        @foreach (var item in order.Items)
                                        {
                                            <div class="item-row">
                                                <div class="item-name">
                                                    @item.ProductName
                                                    <span class="item-qty">x@item.Quantity</span>
                                                </div>
                                                <div class="item-price">₱@item.Price</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>