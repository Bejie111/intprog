@model List<BreadBee.Models.Category>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/category-management.css" />

<!-- HEADER -->
<div class="cm-header">
    <div>
        <div class="cm-title">📂 Category Management</div>
        <div class="cm-subtitle">Organize your bread products by category</div>
    </div>
    <a asp-action="Create" class="btn-add-category">
        <i class="bi bi-plus-lg"></i> Add Category
    </a>
</div>

<!-- TABLE CARD -->
<div class="cm-card">
    <div class="cm-card-header">
        <span class="cm-card-title">
            <i class="bi bi-folder-fill"></i> All Categories
        </span>
        <span class="cm-count">@Model.Count categories</span>
    </div>

    <div class="table-wrap">
        <table class="cm-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Category Name</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr class="cm-row">
                        <td>
                            <span class="id-badge">#@c.Id</span>
                        </td>
                        <td>
                            <div class="category-cell">
                                <div class="category-icon">📁</div>
                                <span class="category-name">@c.Name</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="action-btns">
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn-edit">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@c.Id"
                                   class="btn-delete"
                                   onclick="return confirm('Are you sure you want to delete this category?')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>