@model List<BreadBee.Models.Product>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>🍞 Product Management</h2>

<form method="get" class="mb-3">

    <input type="text"
           name="search"
           value="@ViewBag.Search"
           placeholder="Search product..."
           class="form-control"
           style="max-width:300px; display:inline-block;" />

    <button class="btn btn-primary">
        Search
    </button>

</form>
<a asp-action="Create" class="btn btn-primary mb-3">
    + Add Product
</a>

<div style="max-height:500px; overflow-y:auto; border:1px solid #ddd;">
    <table class="table table-bordered table-striped mb-0">

        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <img src="@p.ImageUrl"
                             style="width:60px; height:60px; object-fit:cover;" />
                    </td>

                    <td>@p.Name</td>
                    <td>@p.Category?.Name</td>
                    <td>₱@p.Price</td>
                    <td>@p.Stock</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@p.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@p.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete product?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>
