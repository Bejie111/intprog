@model List<BreadBee.Models.Cart>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/checkout.css" />

<div class="checkout-wrapper">

    <div class="checkout-title">
        🧾 Checkout
    </div>

    <form asp-action="PlaceOrder" method="post">

        <!-- DELIVERY DETAILS -->
        <div class="checkout-card">
            <div class="section-label">📦 Delivery Details</div>

            @if (Context.Session.GetInt32("UserId") == null)
            {
                <div class="form-group">
                    <label>Full Name</label>
                    <input name="CustomerName" class="form-control" required placeholder="Enter your full name" />
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input name="ContactNumber" class="form-control" required placeholder="Enter your phone number" />
                </div>
            }
            else
            {
                <input type="hidden" name="CustomerName"
                       value="@Context.Session.GetString("Name")" />
            }

            <div class="form-group">
                <label>Address</label>
                <input name="Address" class="form-control" required placeholder="Enter your delivery address" />
            </div>
        </div>

        <!-- ORDER SUMMARY -->
        <div class="checkout-card">
            <div class="section-label">🛒 Order Summary</div>

            @foreach (var item in Model)
            {
                <div class="order-item">
                    <div>
                        <div class="order-item-name">@item.ProductName</div>
                        <div class="order-item-qty">x@item.Quantity</div>
                    </div>
                    <div class="order-item-price">₱@(item.Price* item.Quantity)</div>
                </div>
            }

            <div class="total-row">
                <span class="total-label">Total</span>
                <span class="total-amount">₱@Model.Sum(x => x.Price * x.Quantity)</span>
            </div>
        </div>

        <!-- BUTTONS -->
        <div class="checkout-actions">
            <button type="submit" class="btn-place-order">✅ Place Order</button>
            <a href="/Product/Products" class="btn-cancel">✕ Cancel</a>
        </div>

    </form>
</div>