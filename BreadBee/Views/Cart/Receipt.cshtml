@model BreadBee.Models.Order

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/receipt.css" />

<div class="receipt-wrapper">

    <!-- HEADER -->
    <div class="receipt-header">
        <div class="receipt-title">🧾 Order Receipt</div>
        <div class="receipt-badge">✅ Order Confirmed</div>
    </div>

    <!-- ORDER INFO -->
    <div class="receipt-card">
        <div class="section-label">📋 Order Details</div>
        <div class="info-grid">
            <div class="info-item">
                <div class="info-label">Order ID</div>
                <div class="info-value">#@Model.Id</div>
            </div>
            <div class="info-item">
                <div class="info-label">Name</div>
                <div class="info-value">@Model.CustomerName</div>
            </div>
            <div class="info-item">
                <div class="info-label">Phone</div>
                <div class="info-value">@Model.ContactNumber</div>
            </div>
            <div class="info-item">
                <div class="info-label">Address</div>
                <div class="info-value">@Model.Address</div>
            </div>
            <div class="info-item">
                <div class="info-label">Date</div>
                <div class="info-value">@Model.OrderDate</div>
            </div>
        </div>
    </div>

    <!-- ITEMS TABLE -->
    <div class="receipt-card">
        <div class="section-label">🛒 Items Ordered</div>
        <table class="receipt-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="product-name-cell">@item.ProductName</td>
                        <td><span class="qty-badge">x@item.Quantity</span></td>
                        <td>₱@item.Price.ToString("F2")</td>
                        <td class="item-total">₱@((item.Price * item.Quantity).ToString("F2"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- SUMMARY -->
    <div class="receipt-card">
        <div class="section-label">💰 Summary</div>
        <div class="summary-row">
            <span class="summary-key">Subtotal</span>
            <span class="summary-val">₱@Model.TotalAmount.ToString("F2")</span>
        </div>
        <div class="summary-row discount">
            <span class="summary-key">Discount</span>
            <span class="summary-val discount-val">- ₱@Model.Discount.ToString("F2")</span>
        </div>
        <div class="summary-total-row">
            <span class="summary-total-label">Final Total</span>
            <span class="summary-total-amount">₱@Model.FinalAmount.ToString("F2")</span>
        </div>
    </div>

    <!-- BUTTON -->
    <div class="receipt-actions">
        <a href="/Product/Products" class="btn-continue">🍞 Continue Shopping</a>
    </div>

</div>