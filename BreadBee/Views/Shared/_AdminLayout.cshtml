<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BreadBee</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BreadBee.styles.css" asp-append-version="true" />
    <style>
        body {
        margin: 0;
        }

        .admin-wrapper {
        display: flex;
        min-height: 100vh;
        }

        .sidebar {
        width: 250px;
        background: #212529;
        color: white;
        padding: 20px;
        }

        .sidebar a {
        display: block;
        color: white;
        padding: 10px;
        text-decoration: none;
        border-radius: 5px;
        margin-bottom: 5px;
        }

        .sidebar a:hover {
        background: #343a40;
        }

        .content {
        flex: 1;
        padding: 20px;
        background: #f8f9fa;
        }
    </style>
</head>

<body>
    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <h4>🛠 Admin Panel</h4>
            <hr />

            <a asp-controller="Admin" asp-action="Dashboard">
                📊 Dashboard
            </a>

            <a asp-controller="UserManagement" asp-action="UserManagement">
                👤 User Management
            </a>

            <a asp-controller="ProductManagement" asp-action="ProductManagement">
                🍞 Product Management
            </a>

            <a asp-controller="CategoryManagement" asp-action="CategoryManagement">
                📂 Category Management
            </a>

            <a asp-controller="User" asp-action="Profile">
                ⚙️ Profile Settings
            </a>
            <a class="text-danger"
               asp-controller="Account"
               asp-action="Logout">
                Logout
            </a>

        </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BreadBee - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
