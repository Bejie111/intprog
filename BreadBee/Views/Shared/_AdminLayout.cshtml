<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BreadBee Admin</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BreadBee.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" />
</head>

<body>
    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <!-- BRAND -->
            <div class="sidebar-brand">
                <div class="brand-icon">🐝</div>
                <div class="brand-text">
                    BreadBee
                    <span>Admin</span>
                </div>
            </div>

            <div class="sidebar-divider"></div>

            <!-- CORE -->
            <div class="sidebar-caption">Core</div>
            <a asp-controller="Admin" asp-action="Dashboard" class="sidebar-link">
                <div class="link-icon"><i class="bi bi-grid-1x2-fill"></i></div>
                <span>Dashboard</span>
            </a>

            <!-- MANAGEMENT -->
            <div class="sidebar-caption">Management</div>
            <a asp-controller="UserManagement" asp-action="Index" class="sidebar-link">
                <div class="link-icon"><i class="bi bi-people-fill"></i></div>
                <span>User Management</span>
            </a>
            <a asp-controller="ProductManagement" asp-action="Index" class="sidebar-link">
                <div class="link-icon"><i class="bi bi-basket3-fill"></i></div>
                <span>Product Management</span>
            </a>
            <a asp-controller="CategoryManagement" asp-action="Index" class="sidebar-link">
                <div class="link-icon"><i class="bi bi-folder-fill"></i></div>
                <span>Category Management</span>
            </a>

            <!-- SYSTEM -->
            <div class="sidebar-caption">System</div>
            <a asp-controller="User" asp-action="Profile" class="sidebar-link">
                <div class="link-icon"><i class="bi bi-sliders"></i></div>
                <span>Profile Settings</span>
            </a>

            <!-- BOTTOM PROFILE + LOGOUT -->
            <div class="sidebar-bottom">
                <div class="sidebar-divider"></div>
                <div class="sidebar-profile">
                    <div class="profile-avatar">
                        @(Context.Session.GetString("Name")?[0].ToString().ToUpper() ?? "A")
                    </div>
                    <div class="profile-info">
                        <span class="profile-name">
                            @(Context.Session.GetString("Name") ?? "Administrator")
                        </span>
                    </div>
                </div>
                <a class="sidebar-link logout-link" asp-controller="Account" asp-action="Logout">
                    <div class="link-icon"><i class="bi bi-power"></i></div>
                    <span>Logout</span>
                </a>
            </div>

        </div>
        <!-- END SIDEBAR -->

        <div class="content-wrapper">
            <main role="main" class="main-content">
                @RenderBody()
            </main>
            <footer class="admin-footer text-muted">
                &copy; 2026 - BreadBee Studio -
                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="text-secondary text-decoration-none fw-bold">Privacy</a>
            </footer>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Auto highlight active sidebar link
        const links = document.querySelectorAll('.sidebar-link');
        links.forEach(link => {
            if (link.href === window.location.href) {
                link.classList.add('active-link');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>