@using BreadBee.Models
@using System.Text.Json
@{
    var cartJson = Context.Session.GetString("Cart");

    var cart = cartJson != null
        ? JsonSerializer.Deserialize<List<Cart>>(cartJson)
        : new List<Cart>();

    var cartTotal = cart.Sum(x => x.Price * x.Quantity);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BreadBee</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/cart.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BreadBee.styles.css" asp-append-version="true" />
    <partial name="_Header" />
   
</head>
<body>
    <div style="display:flex;">

        <!-- MAIN CONTENT -->
        <div style="flex:1; padding:20px;">
            @RenderBody()
        </div>

        <!-- CART SIDEBAR -->
        <div class="cart-sidebar">
            <div class="cart-header">
                <span class="cart-header-icon">🛒</span>
                <span class="cart-header-title">My Cart</span>
            </div>

            @if (cart.Count == 0)
            {
                <div class="cart-empty">
                    <div class="cart-empty-icon">🍞</div>
                    <p>No items yet</p>
                    <small>Add some fresh bread!</small>
                </div>
            }
            else
            {
                <div class="cart-items">
                    @foreach (var item in cart)
                    {
                        <div class="cart-item">
                            <img src="@item.ImageUrl"
                                 class="cart-item-img"
                                 onerror="this.src='https://images.unsplash.com/photo-1509440159596-0249088772ff?w=100'" />
                            <div class="cart-item-info">
                                <div class="cart-item-name">@item.ProductName</div>
                                <div class="cart-item-price">₱@(item.Price* item.Quantity)</div>
                                <div class="cart-item-qty">
                                    <a href="/Cart/Decrease?id=@item.ProductId" class="qty-btn">−</a>
                                    <span class="qty-num">@item.Quantity</span>
                                    <a href="/Cart/Increase?id=@item.ProductId" class="qty-btn">+</a>
                                </div>
                            </div>
                            <a href="/Cart/Remove?id=@item.ProductId" class="cart-item-remove">✕</a>
                        </div>
                    }
                </div>

                <div class="cart-divider"></div>

                <div class="cart-total">
                    <span>Total</span>
                    <span class="cart-total-amount">₱@cartTotal</span>
                </div>

                <div class="cart-actions">
                    @if (cart.Count > 0)
                    {
                        <a asp-controller="Cart"
                           asp-action="CheckOut"
                           class="btn-checkout">
                            🧾 Checkout
                        </a>
                    }
                    else
                    {
                        <a class="btn-checkout disabled">🧾 Checkout</a>
                    }

                    <a asp-controller="Cart"
                       asp-action="Clear"
                       class="btn-clear">
                        🗑️ Clear Cart
                    </a>
                </div>
            }
        </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>